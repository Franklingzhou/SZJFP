<web-view 
  wx:if="{{url}}" 
  src="{{url}}" 
  bindmessage="onMessage"
  bindload="onLoadDone"
  binderror="onLoadError"
></web-view>

<!-- 加载中 -->
<view wx:if="{{loading && url}}" class="loading-container">
  <view class="loading-spinner"></view>
  <text class="loading-text">正在加载页面...</text>
</view>

<!-- 加载失败 -->
<view wx:if="{{error}}" class="error-container">
  <view class="error-icon">!</view>
  <text class="error-title">页面加载失败</text>
  <text class="error-msg">{{errorMsg}}</text>
  <view class="error-actions">
    <view class="btn-retry" bindtap="onRetry">重试</view>
    <view class="btn-copy" bindtap="onCopyLink">复制链接在浏览器打开</view>
  </view>
  <view class="error-tip">
    <text>提示：如果是域名限制，请在微信开发者工具</text>
    <text>「详情 → 本地设置」勾选</text>
    <text>「不校验合法域名」</text>
  </view>
  <view class="btn-home" bindtap="onBackHome">返回首页</view>
</view>
