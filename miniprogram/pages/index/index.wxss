.container {
  padding: 40rpx 30rpx;
  min-height: 100vh;
  background: #f8fafc;
}

.header {
  text-align: center;
  margin-bottom: 50rpx;
}

.title {
  display: block;
  font-size: 44rpx;
  font-weight: 600;
  color: #1e3a5f;
  margin-bottom: 12rpx;
}

.subtitle {
  display: block;
  font-size: 28rpx;
  color: #94a3b8;
}

/* 微信一键登录 */
.wechat-login-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 16rpx;
  background: #07c160;
  color: #fff;
  border-radius: 20rpx;
  padding: 32rpx;
  margin-bottom: 40rpx;
  font-size: 34rpx;
  font-weight: 600;
}

.wechat-login-btn:active {
  opacity: 0.85;
  transform: scale(0.98);
}

.wechat-icon {
  font-size: 40rpx;
}

/* 分割线 */
.divider {
  display: flex;
  align-items: center;
  gap: 20rpx;
  margin-bottom: 36rpx;
}

.divider-line {
  flex: 1;
  height: 1rpx;
  background: #e2e8f0;
}

.divider-text {
  font-size: 24rpx;
  color: #94a3b8;
}

/* 已登录状态 */
.logged-in .user-badge {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  margin-top: 20rpx;
  padding: 16rpx 32rpx;
  background: rgba(245, 158, 11, 0.1);
  border-radius: 40rpx;
  display: inline-flex;
}

.logged-in .user-icon {
  font-size: 36rpx;
}

.logged-in .user-name {
  font-size: 28rpx;
  color: #f59e0b;
  font-weight: 600;
}

.workspace-card {
  display: flex;
  align-items: center;
  gap: 24rpx;
  background: #fff;
  border-radius: 20rpx;
  padding: 36rpx;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.08);
  margin-bottom: 30rpx;
}

.workspace-card:active {
  opacity: 0.85;
  transform: scale(0.98);
}

.workspace-icon {
  font-size: 64rpx;
}

.workspace-info {
  flex: 1;
}

.workspace-title {
  display: block;
  font-size: 34rpx;
  font-weight: 600;
  color: #1e3a5f;
  margin-bottom: 8rpx;
}

.workspace-desc {
  display: block;
  font-size: 24rpx;
  color: #94a3b8;
}

.workspace-arrow {
  font-size: 48rpx;
  color: #cbd5e1;
}

.logout-btn {
  text-align: center;
  padding: 24rpx;
  color: #ef4444;
  font-size: 30rpx;
  margin-top: 20rpx;
}

.logout-btn:active {
  opacity: 0.7;
}

/* 角色卡片 */
.role-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 24rpx;
  justify-content: space-between;
}

.role-card {
  width: 48%;
  background: #fff;
  border-radius: 20rpx;
  padding: 36rpx 24rpx;
  text-align: center;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.06);
  margin-bottom: 8rpx;
}

.role-card:active {
  opacity: 0.85;
  transform: scale(0.98);
}

.role-icon {
  display: block;
  font-size: 56rpx;
  margin-bottom: 16rpx;
}

.role-name {
  display: block;
  font-size: 32rpx;
  font-weight: 600;
  color: #1e3a5f;
  margin-bottom: 8rpx;
}

.role-desc {
  display: block;
  font-size: 24rpx;
  color: #94a3b8;
}

.admin-btn {
  margin-top: 50rpx;
  text-align: center;
  padding: 24rpx;
  background: #1e3a5f;
  color: #fff;
  border-radius: 16rpx;
  font-size: 30rpx;
}

.admin-btn:active {
  opacity: 0.85;
}
