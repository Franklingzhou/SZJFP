<view class="container">
  <!-- 已登录状态 -->
  <view wx:if="{{isLoggedIn && userInfo}}" class="logged-in">
    <view class="header">
      <text class="title">家政共创平台</text>
      <view class="user-badge">
        <text class="user-icon">{{roles[userInfo.role] || '👤'}}</text>
        <text class="user-name">{{userInfo.name}}</text>
      </view>
    </view>
    
    <view class="workspace-card" bindtap="onEnterWorkspace">
      <text class="workspace-icon">🚀</text>
      <view class="workspace-info">
        <text class="workspace-title">进入工作台</text>
        <text class="workspace-desc">{{userInfo.role}} · 点击进入</text>
      </view>
      <text class="workspace-arrow">›</text>
    </view>

    <view class="logout-btn" bindtap="onLogout">
      <text>退出登录</text>
    </view>
  </view>

  <!-- 未登录状态 -->
  <view wx:else class="not-logged-in">
    <view class="header">
      <text class="title">家政共创平台</text>
      <text class="subtitle">选择角色进入</text>
    </view>

    <!-- 微信一键登录 -->
    <view class="wechat-login-btn" bindtap="onWechatLogin">
      <text class="wechat-icon">📱</text>
      <text class="wechat-text">微信一键登录</text>
    </view>

    <view class="divider">
      <view class="divider-line"></view>
      <text class="divider-text">或选择角色</text>
      <view class="divider-line"></view>
    </view>

    <view class="role-grid">
      <view class="role-card" wx:for="{{roles}}" wx:key="key"
            data-role="{{item.key}}" bindtap="onSelectRole">
        <text class="role-icon">{{item.icon}}</text>
        <text class="role-name">{{item.name}}</text>
        <text class="role-desc">{{item.desc}}</text>
      </view>
    </view>
  </view>

  <view class="admin-btn" bindtap="onOpenAdmin">
    <text>管理后台</text>
  </view>
</view>
