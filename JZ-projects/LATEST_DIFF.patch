 import { relations } from "drizzle-orm/relations";
-import {  } from "./schema";
+import { users, workers, worker_media, worker_work_experience, customers, leads, lead_follow_ups, courses, enrollments, orders, settlements, reviews } from "./schema";
 
+export const usersRelations = relations(users, ({ many, one }) => ({
+  worker: one(workers, { fields: [users.id], references: [workers.user_id] }),
+  customer: one(customers, { fields: [users.id], references: [customers.user_id] }),
+  workersAsCreator: many(workers),
+  ordersAsAgent: many(orders),
+}));
+
+export const workersRelations = relations(workers, ({ one, many }) => ({
+  user: one(users, { fields: [workers.user_id], references: [users.id] }),
+  creator: one(users, { fields: [workers.creator_id], references: [users.id] }),
+  maintainer: one(users, { fields: [workers.maintainer_id], references: [users.id] }),
+  referrer: one(users, { fields: [workers.referrer_id], references: [users.id] }),
+  media: many(worker_media),
+  workExperience: many(worker_work_experience),
+}));
+
+export const ordersRelations = relations(orders, ({ one, many }) => ({
+  agent: one(users, { fields: [orders.agent_id], references: [users.id] }),
+  settlements: many(settlements),
+  reviews: many(reviews),
+}));
+
+export const reviewsRelations = relations(reviews, ({ one }) => ({
+  targetUser: one(users, { fields: [reviews.target_user_id], references: [users.id] }),
+  reviewer: one(users, { fields: [reviews.reviewer_id], references: [users.id] }),
+  order: one(orders, { fields: [reviews.order_id], references: [orders.id] }),
+}));
+
+export const coursesRelations = relations(courses, ({ one, many }) => ({
+  instructor: one(users, { fields: [courses.instructor_id], references: [users.id] }),
+  enrollments: many(enrollments),
+}));
+
+export const leadsRelations = relations(leads, ({ one, many }) => ({
+  recruiter: one(users, { fields: [leads.recruiter_id], references: [users.id] }),
+  followUps: many(lead_follow_ups),
+}));
