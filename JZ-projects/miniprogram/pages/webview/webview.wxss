/* 加载中 */
.loading-container {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  height: 100vh;
  background: #f8fafc;
}

.loading-spinner {
  width: 40px;
  height: 40px;
  border: 3px solid #e2e8f0;
  border-top-color: #1e3a5f;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.loading-text {
  margin-top: 16px;
  font-size: 14px;
  color: #64748b;
}

/* 加载失败 */
.error-container {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  height: 100vh;
  padding: 40rpx;
  background: #ffffff;
}

.error-icon {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #f59e0b, #f97316);
  color: #fff;
  font-size: 40rpx;
  font-weight: bold;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 24rpx;
}

.error-title {
  font-size: 18px;
  font-weight: 600;
  color: #1e293b;
  margin-bottom: 12rpx;
}

.error-msg {
  font-size: 14px;
  color: #64748b;
  text-align: center;
  margin-bottom: 40rpx;
}

.error-actions {
  display: flex;
  gap: 24rpx;
  margin-bottom: 48rpx;
}

.btn-retry {
  padding: 16rpx 48rpx;
  background: #1e3a5f;
  color: #fff;
  border-radius: 12rpx;
  font-size: 14px;
}

.btn-copy {
  padding: 16rpx 48rpx;
  background: #f8fafc;
  color: #1e3a5f;
  border: 1px solid #e2e8f0;
  border-radius: 12rpx;
  font-size: 14px;
}

.error-tip {
  background: #fffbeb;
  border: 1px solid #fde68a;
  border-radius: 12rpx;
  padding: 24rpx;
  margin-bottom: 32rpx;
  max-width: 600rpx;
}

.error-tip text {
  display: block;
  font-size: 12px;
  color: #92400e;
  line-height: 1.6;
}

.btn-home {
  padding: 16rpx 48rpx;
  background: #f8fafc;
  color: #64748b;
  border-radius: 12rpx;
  font-size: 14px;
}
