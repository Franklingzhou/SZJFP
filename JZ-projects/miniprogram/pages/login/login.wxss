.container {
  padding: 60rpx 40rpx;
  min-height: 100vh;
  background: #f8fafc;
}

/* 加载状态 */
.loading {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  min-height: 80vh;
}

.loading-spinner {
  width: 80rpx;
  height: 80rpx;
  border: 6rpx solid #e2e8f0;
  border-top-color: #f59e0b;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
  margin-bottom: 24rpx;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.loading-text {
  font-size: 28rpx;
  color: #94a3b8;
}

/* 已登录 */
.logged-in {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding-top: 120rpx;
}

.success-icon {
  font-size: 100rpx;
  margin-bottom: 30rpx;
}

.success-title {
  display: block;
  font-size: 40rpx;
  font-weight: 600;
  color: #1e3a5f;
  margin-bottom: 16rpx;
}

.success-name {
  display: block;
  font-size: 32rpx;
  color: #475569;
  margin-bottom: 8rpx;
}

.success-role {
  display: block;
  font-size: 28rpx;
  color: #94a3b8;
  margin-bottom: 80rpx;
}

.workspace-btn {
  width: 100%;
  padding: 32rpx;
  background: #f59e0b;
  color: #fff;
  border-radius: 20rpx;
  text-align: center;
  font-size: 34rpx;
  font-weight: 600;
  margin-bottom: 30rpx;
}

.workspace-btn:active {
  opacity: 0.85;
}

.logout-btn {
  padding: 24rpx;
  color: #ef4444;
  font-size: 30rpx;
  text-align: center;
}

/* 新用户注册 */
.register {
  padding-top: 60rpx;
}

.register-header {
  text-align: center;
  margin-bottom: 50rpx;
}

.register-icon {
  display: block;
  font-size: 80rpx;
  margin-bottom: 20rpx;
  text-align: center;
}

.register-title {
  display: block;
  font-size: 40rpx;
  font-weight: 600;
  color: #1e3a5f;
  margin-bottom: 12rpx;
  text-align: center;
}

.register-desc {
  display: block;
  font-size: 28rpx;
  color: #94a3b8;
  text-align: center;
}

.role-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
  justify-content: space-between;
  margin-bottom: 40rpx;
}

.role-card {
  width: 48%;
  background: #fff;
  border-radius: 16rpx;
  padding: 30rpx 20rpx;
  text-align: center;
  border: 3rpx solid #e2e8f0;
  position: relative;
}

.role-card.selected {
  border-color: #22c55e;
  background: #f0fdf4;
}

.role-icon {
  display: block;
  font-size: 48rpx;
  margin-bottom: 12rpx;
}

.role-name {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  color: #1e3a5f;
}

.check-icon {
  position: absolute;
  top: 10rpx;
  right: 16rpx;
  color: #22c55e;
  font-size: 32rpx;
  font-weight: bold;
}

.register-form {
  margin-bottom: 30rpx;
}

.register-input {
  width: 100%;
  padding: 28rpx 30rpx;
  background: #fff;
  border: 2rpx solid #e2e8f0;
  border-radius: 16rpx;
  font-size: 30rpx;
  margin-bottom: 20rpx;
  box-sizing: border-box;
}

.register-btn {
  width: 100%;
  padding: 32rpx;
  background: #22c55e;
  color: #fff;
  border-radius: 20rpx;
  text-align: center;
  font-size: 34rpx;
  font-weight: 600;
}

.register-btn.disabled {
  background: #cbd5e1;
}

.register-btn:active:not(.disabled) {
  opacity: 0.85;
}

/* 未登录 */
.not-logged-in {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding-top: 200rpx;
}

.login-icon {
  font-size: 100rpx;
  margin-bottom: 30rpx;
}

.login-title {
  display: block;
  font-size: 40rpx;
  font-weight: 600;
  color: #1e3a5f;
  margin-bottom: 16rpx;
}

.login-desc {
  display: block;
  font-size: 28rpx;
  color: #94a3b8;
  margin-bottom: 80rpx;
}

.wechat-btn {
  width: 100%;
  padding: 32rpx;
  background: #07c160;
  color: #fff;
  border-radius: 20rpx;
  text-align: center;
  font-size: 34rpx;
  font-weight: 600;
}

.wechat-btn:active {
  opacity: 0.85;
}
