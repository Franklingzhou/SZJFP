<view class="container">
  <!-- 加载中 -->
  <view wx:if="{{loading}}" class="loading">
    <view class="loading-spinner"></view>
    <text class="loading-text">正在登录...</text>
  </view>

  <!-- 已登录 -->
  <view wx:elif="{{isLoggedIn && userInfo}}" class="logged-in">
    <view class="success-icon">✅</view>
    <text class="success-title">登录成功</text>
    <text class="success-name">{{userInfo.name}}</text>
    <text class="success-role">{{userInfo.role}}</text>

    <view class="workspace-btn" bindtap="onEnterWorkspace">
      <text>进入工作台</text>
    </view>

    <view class="logout-btn" bindtap="onLogout">
      <text>退出登录</text>
    </view>
  </view>

  <!-- 新用户注册 -->
  <view wx:elif="{{isNewUser}}" class="register">
    <view class="register-header">
      <text class="register-icon">📱</text>
      <text class="register-title">微信登录</text>
      <text class="register-desc">首次使用，请选择身份</text>
    </view>

    <view class="role-grid">
      <view class="role-card {{selectedRole === item.key ? 'selected' : ''}}" 
            wx:for="{{roles}}" wx:key="key"
            data-role="{{item.key}}" bindtap="onSelectRole">
        <text class="role-icon">{{item.icon}}</text>
        <text class="role-name">{{item.name}}</text>
        <view wx:if="{{selectedRole === item.key}}" class="check-icon">✓</view>
      </view>
    </view>

    <view wx:if="{{selectedRole}}" class="register-form">
      <input class="register-input" placeholder="姓名（选填）" 
             value="{{registerName}}" bindinput="onInputName" />
      <input class="register-input" placeholder="手机号（选填）" type="number"
             value="{{registerPhone}}" bindinput="onInputPhone" />
    </view>

    <view class="register-btn {{selectedRole ? '' : 'disabled'}}" 
          bindtap="{{selectedRole ? 'onRegister' : ''}}">
      <text>{{logging ? '注册中...' : '确认注册'}}</text>
    </view>
  </view>

  <!-- 未登录 -->
  <view wx:else class="not-logged-in">
    <view class="login-icon">🔐</view>
    <text class="login-title">家政共创平台</text>
    <text class="login-desc">请点击登录</text>

    <view class="wechat-btn" bindtap="autoLogin">
      <text>📱 微信一键登录</text>
    </view>
  </view>
</view>
